knowledge/bm25_index.json
# Conteúdo gated extraído de pacotes Festo customer-portal — nunca redistribuir.
# Cada usuário regenera localmente via scripts/extract-festo-package.ts a partir
# dos .package que ele próprio baixou do portal.
knowledge/external/

# Python venv pros wrappers Festo (cpx-io + edcon) — regenerado via
# `npm run python:install` (uv sync). Source: python/pyproject.toml + uv.lock.
python/.venv/
python/**/__pycache__/
python/**/*.pyc

# truST LSP index cache — regenerado pela extensao VS Code do truST ao abrir o repo.
.trust-lsp/
