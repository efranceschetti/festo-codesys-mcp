node_modules/
build/
coverage/
*.js.map
*.d.ts
!src/**/*.d.ts
.env
.DS_Store
# Raw HTML dumps from docs-harvest/harvest.py (regenerable)
docs-harvest/_raw/
# Claude Code: settings local-only (config por máquina)
.claude/settings.local.json
# BM25 index é regenerável a partir dos .md em knowledge/
